# ====================================================
# Bolt 环境变量模板
# 复制为 .env 并填入实际值：cp .env.example .env
# docker-compose 自动加载；本地开发需 source .env 或 IDE 配置
# ====================================================

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_password_here
REDIS_DATABASE=0

# Server
SERVER_PORT=9292

# Spring
SPRING_PROFILES_ACTIVE=dev

# Log
LOG_LEVEL=INFO
LOG_PATH=/var/log/bolt
